{
  "name": "eslint-typescript-mcp",
  "version": "1.1.0",
  "description": "MCP server that brings ESLint and TypeScript type-checking diagnostics to Claude Code — enables LLMs to lint, fix, and type-check code automatically, with per-file targeting and dry-run support for multi-agent workflows",
  "keywords": [
    "mcp",
    "eslint",
    "typescript",
    "claude",
    "claude-code",
    "ai-tools",
    "developer-tools",
    "linting",
    "typecheck",
    "mcp-server",
    "static-analysis",
    "dry-run",
    "multi-agent"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eslint-typescript-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run build",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/w334-jpg/eslint-typescript-mcp"
  },
  "license": "MIT",
  "author": "w334-jpg",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "execa": "^9.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.0"
  }
}
